---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiagnosticGuide from '../../components/diagnostic/DiagnosticGuide.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const fil = [
  { name: 'Accueil', url: '/' },
  { name: 'Diagnostic', url: '/diagnostic' },
  { name: 'Ça pique aux yeux', url: '/diagnostic/pique-aux-yeux' },
];
---

<BaseLayout
  title="L’eau de la piscine pique aux yeux : diagnostic | EauTopie"
  description="Les yeux qui piquent à la piscine ? Ce n’est pas (toujours) le chlore. Réponds à quelques questions, on identifie la vraie cause et la solution."
>
  <section class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
    <Breadcrumbs items={fil} class="mb-6" />
    <div class="mb-8 text-center">
      <p class="mb-3 inline-flex items-center gap-2 rounded-full bg-soleil/15 px-3 py-1 text-sm font-medium text-soleil">
        🔬 Diagnostic guidé
      </p>
      <h1 class="text-3xl text-noir-eau sm:text-4xl">Ça pique aux yeux</h1>
      <p class="mx-auto mt-3 max-w-xl text-gris-onde">
        Souvent ce n’est pas un excès de chlore, mais l’inverse ! Réponds à
        quelques questions pour trouver la vraie cause.
      </p>
    </div>

    <DiagnosticGuide slug="pique-aux-yeux" />

    <p class="mx-auto mt-6 max-w-2xl text-center text-xs text-gris-onde">
      Diagnostic indicatif. Pour comprendre,
      <a href="/blog/eau-piscine-pique-aux-yeux" class="text-bleu-eau hover:underline">lis notre article sur les irritations</a>.
    </p>
  </section>
</BaseLayout>
