---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout
  title="Le blog EauTopie — apprends l’entretien de ta piscine"
  description="Guides, astuces et explications pour entretenir ta piscine comme un pro. Le blog EauTopie arrive bientôt."
>
  <section class="mx-auto max-w-2xl px-6 py-20 text-center">
    <div class="text-6xl" aria-hidden="true">📚</div>
    <h1 class="mt-6 text-4xl text-noir-eau">Le blog arrive bientôt</h1>
    <p class="mt-4 text-lg text-gris-onde">
      On prépare des guides clairs pour t’apprendre l’entretien de ta piscine,
      du débutant total au pro de l’eau cristalline.
    </p>
    <div class="mt-8">
      <Button href="/" variant="primary" size="lg">Retour à l’accueil</Button>
    </div>
  </section>
</BaseLayout>
