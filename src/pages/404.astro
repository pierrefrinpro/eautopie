---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout
  title="Page introuvable — EauTopie"
  description="Oups, cette page n’existe pas (ou plus). Reviens à l’accueil pour retrouver tes calculateurs."
  noindex={true}
>
  <section class="mx-auto max-w-2xl px-6 py-20 text-center sm:py-28">
    <div class="text-7xl" aria-hidden="true">💧</div>
    <p class="mt-4 font-display text-6xl font-semibold text-bleu-eau">404</p>
    <h1 class="mt-3 text-3xl text-noir-eau sm:text-4xl">
      Cette page a coulé…
    </h1>
    <p class="mx-auto mt-4 max-w-md text-lg text-gris-onde">
      La page que tu cherches n’existe pas (ou plus). Pas de panique, on te
      ramène en eaux calmes.
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <Button href="/" variant="primary" size="lg">Retour à l’accueil</Button>
      <Button href="/calculateur/chlore" variant="secondary" size="lg">
        Calculer mon chlore
      </Button>
    </div>
  </section>
</BaseLayout>
