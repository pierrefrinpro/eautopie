---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniCalc from '../../components/calculators/MiniCalc.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Faq from '../../components/Faq.astro';
import PremiumButton from '../../components/ui/PremiumButton.astro';

const SITE = 'https://eautopie.fr';
const fil = [
  { name: 'Accueil', url: '/' },
  { name: 'Calculateurs', url: '/calculateur' },
  { name: 'Anti-algues', url: '/calculateur/anti-algues' },
];
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Calculateur d’anti-algues piscine',
    description:
      'Calcule la dose d’anti-algues à ajouter selon ton volume, en préventif ou en curatif.',
    applicationCategory: 'UtilityApplication',
    operatingSystem: 'Web',
    url: `${SITE}/calculateur/anti-algues`,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'EUR',
      availability: 'https://schema.org/InStock',
    },
  },
];
const champs = [
  { id: 'volume', label: 'Volume de la piscine', suffix: 'm³', placeholder: 'Ex: 25' },
  {
    id: 'mode',
    label: 'Type de traitement',
    type: 'select' as const,
    options: [
      { value: 'preventif', label: 'Préventif (entretien) — 5 ml/m³' },
      { value: 'curatif', label: 'Curatif (eau qui vire) — 15 ml/m³' },
    ],
  },
];
const note =
  'Dose indicative — vérifie ton produit. En <strong>curatif</strong>, ajoute l’anti-algues quelques heures après un chlore choc, filtration en marche.';
const faqItems = [
  {
    question: 'Quand mettre de l’anti-algues ?',
    answer:
      'En préventif, régulièrement pendant la saison pour empêcher les algues. En curatif, juste après un chlore choc quand l’eau a viré, pour empêcher les algues de repartir.',
  },
  {
    question: 'Anti-algues avant ou après le chlore choc ?',
    answer:
      'Toujours le chlore choc d’abord (il détruit les algues), puis l’anti-algues quelques heures après pour le préventif.',
  },
];
---

<BaseLayout
  title="Calculateur d’anti-algues piscine (dose par m³) | EauTopie"
  description="Quelle dose d’anti-algues pour ta piscine ? Calcule la quantité en préventif ou en curatif selon ton volume. Gratuit et sans inscription."
  schemas={schemas}
>
  <section class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
    <Breadcrumbs items={fil} class="mb-6" />
    <div class="mb-8 text-center">
      <p class="mb-3 inline-flex items-center gap-2 rounded-full bg-bleu-pale px-3 py-1 text-sm font-medium text-bleu-profond">
        🦠 Calculateur
      </p>
      <h1 class="text-3xl text-noir-eau sm:text-4xl">Anti-algues</h1>
      <p class="mx-auto mt-3 max-w-xl text-gris-onde">
        Préventif ou curatif ? On te dit combien d’anti-algues verser pour ton
        bassin.
      </p>
    </div>

    <MiniCalc kind="anti-algues" champs={champs} note={note} />

    <p class="mx-auto mt-6 max-w-xl text-center text-xs text-gris-onde">
      Estimation indicative. Vérifie la dose conseillée sur ton bidon.
    </p>

    <Faq items={faqItems} class="mx-auto mt-12 max-w-2xl" />

    <div class="mx-auto mt-12 max-w-xl rounded-2xl border border-bleu-pale bg-bleu-pale/30 p-6 text-center">
      <p class="font-display text-lg font-semibold text-noir-eau">
        Ton eau a viré au vert ? 🟢
      </p>
      <div class="mt-4 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/diagnostic/eau-verte" class="inline-flex items-center justify-center rounded-xl bg-bleu-eau px-6 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-bleu-profond">
          Diagnostic eau verte
        </a>
        <PremiumButton source="calculateur-anti-algues" variant="secondary" size="md" />
      </div>
    </div>
  </section>
</BaseLayout>
