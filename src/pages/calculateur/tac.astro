---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniCalc from '../../components/calculators/MiniCalc.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Faq from '../../components/Faq.astro';
import PremiumButton from '../../components/ui/PremiumButton.astro';

const SITE = 'https://eautopie.fr';
const fil = [
  { name: 'Accueil', url: '/' },
  { name: 'Calculateurs', url: '/calculateur' },
  { name: 'TAC (alcalinité)', url: '/calculateur/tac' },
];
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Calculateur de TAC (alcalinité) piscine',
    description:
      'Calcule la dose de bicarbonate de soude pour monter le TAC (alcalinité) de ta piscine vers la zone idéale.',
    applicationCategory: 'UtilityApplication',
    operatingSystem: 'Web',
    url: `${SITE}/calculateur/tac`,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'EUR',
      availability: 'https://schema.org/InStock',
    },
  },
];
const champs = [
  { id: 'volume', label: 'Volume de la piscine', suffix: 'm³', placeholder: 'Ex: 25' },
  { id: 'actuel', label: 'TAC actuel', suffix: 'mg/L', placeholder: 'Ex: 60' },
  { id: 'cible', label: 'TAC visé', suffix: 'mg/L', value: '100' },
];
const note =
  'Le TAC stabilise le pH. Vise <strong>80 à 120 mg/L</strong>. Ajoute le bicarbonate dilué, filtration en marche. Pour le <strong>baisser</strong>, utilise du pH− et aère l’eau.';
const faqItems = [
  {
    question: 'Quel TAC viser pour une piscine ?',
    answer:
      'Entre 80 et 120 mg/L. Un bon TAC empêche le pH de partir dans tous les sens (effet tampon).',
  },
  {
    question: 'TAC et pH, quel lien ?',
    answer:
      'Le TAC stabilise le pH. Si ton pH bouge sans arrêt, c’est souvent que ton TAC est trop bas : remonte-le d’abord.',
  },
];
---

<BaseLayout
  title="Calculateur de TAC piscine (alcalinité) | EauTopie"
  description="Calcule la dose de bicarbonate pour monter le TAC (alcalinité) de ta piscine vers 80–120 mg/L, selon ton volume et ta mesure. Gratuit."
  schemas={schemas}
>
  <section class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
    <Breadcrumbs items={fil} class="mb-6" />
    <div class="mb-8 text-center">
      <p class="mb-3 inline-flex items-center gap-2 rounded-full bg-bleu-pale px-3 py-1 text-sm font-medium text-bleu-profond">
        ⚗️ Calculateur
      </p>
      <h1 class="text-3xl text-noir-eau sm:text-4xl">TAC (alcalinité)</h1>
      <p class="mx-auto mt-3 max-w-xl text-gris-onde">
        Le TAC est le « gardien » de ton pH. On calcule le bicarbonate à ajouter
        pour le ramener dans la bonne zone.
      </p>
    </div>

    <MiniCalc kind="tac" champs={champs} note={note} />

    <p class="mx-auto mt-6 max-w-xl text-center text-xs text-gris-onde">
      Estimation indicative. Ajoute progressivement et re-teste.
    </p>

    <Faq items={faqItems} class="mx-auto mt-12 max-w-2xl" />

    <div class="mx-auto mt-12 max-w-xl rounded-2xl border border-bleu-pale bg-bleu-pale/30 p-6 text-center">
      <p class="font-display text-lg font-semibold text-noir-eau">
        Ton pH ne tient pas en place ?
      </p>
      <div class="mt-4 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/calculateur/ph" class="inline-flex items-center justify-center rounded-xl bg-bleu-eau px-6 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-bleu-profond">
          Calculateur de pH
        </a>
        <PremiumButton source="calculateur-tac" variant="secondary" size="md" />
      </div>
    </div>
  </section>
</BaseLayout>
