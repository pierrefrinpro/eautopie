---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout
  title="Suis ton eau — historique de tes mesures | EauTopie"
  description="Retrouve toutes les mesures que tu as enregistrées : chlore, volume, doses. Suis l’évolution de ton eau dans le temps."
>
  <section class="mx-auto max-w-2xl px-6 py-12 sm:py-16">
    <div class="mb-8 text-center">
      <p
        class="mb-3 inline-flex items-center gap-2 rounded-full bg-vert-ok/15 px-3 py-1 text-sm font-medium text-vert-ok"
      >
        📊 Suis ton eau
      </p>
      <h1 class="text-3xl text-noir-eau sm:text-4xl">Mes mesures</h1>
      <p class="mx-auto mt-3 max-w-xl text-gris-onde">
        L’historique de tes relevés, pour voir d’un coup d’œil comment évolue ton
        eau.
      </p>
      <div
        class="mx-auto mt-5 flex max-w-md items-start gap-2.5 rounded-xl bg-bleu-pale/50 px-4 py-3 text-left text-xs leading-relaxed text-bleu-profond"
      >
        <span class="shrink-0 text-sm" aria-hidden="true">🔒</span>
        <p>
          Tes mesures sont enregistrées <strong>sur cet appareil uniquement</strong>
          — pas de compte, pas de cloud. La sauvegarde sécurisée sur tous tes
          appareils arrive avec le Premium.
        </p>
      </div>
    </div>

    <div data-suivi>
      <div data-suivi-app>
        <p class="text-center text-gris-onde">Chargement de tes mesures…</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import {
    getMesuresChlore,
    supprimerMesureChlore,
    getPlanning,
    type MesureChlore,
    type PlanningSauvegarde,
  } from '../lib/storage';

  function fmtDate(iso: string): string {
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '';
    return (
      d.toLocaleDateString('fr-FR', {
        weekday: 'short',
        day: 'numeric',
        month: 'long',
      }) +
      ' à ' +
      d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })
    );
  }

  const teaserHtml = `
    <div class="mt-8 rounded-3xl bg-gradient-to-br from-bleu-profond to-bleu-eau p-0.5 shadow-md">
      <div class="rounded-[1.4rem] bg-bleu-profond p-6 text-white">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-soleil px-3 py-1 text-xs font-bold uppercase text-noir-eau">⭐ Premium</span>
        <h3 class="mt-3 font-display text-2xl font-semibold">Va plus loin avec le suivi avancé</h3>
        <p class="mt-2 text-sm text-bleu-ciel">
          Graphiques de tes tendances (chlore, pH…), multi-piscines, rappels intelligents et sauvegarde sécurisée sur tous tes appareils.
        </p>
        <div class="relative mt-5">
          <div class="flex h-28 items-end gap-2 blur-[3px]" aria-hidden="true">
            ${[40, 65, 50, 80, 35, 70, 55]
              .map(
                (h) =>
                  `<div class="flex-1 rounded-t-lg bg-bleu-ciel/70" style="height:${h}%"></div>`
              )
              .join('')}
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-white text-2xl shadow-lg" aria-hidden="true">🔒</span>
          </div>
        </div>
        <a href="/premium?source=suivi" class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-soleil px-7 py-3.5 text-base font-semibold text-noir-eau shadow-sm transition hover:brightness-105 active:scale-[0.98]">
          Découvrir Premium — 4,99 €/mois
        </a>
      </div>
    </div>`;

  function initSuivi() {
    const root = document.querySelector<HTMLElement>('[data-suivi]');
    const app = root?.querySelector<HTMLElement>('[data-suivi-app]');
    if (!app) return;

    function cartePlanning(p: PlanningSauvegarde): string {
      const d = new Date(p.date);
      const dateStr = Number.isNaN(d.getTime())
        ? ''
        : d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' });
      const libelle =
        p.type === 'eau-verte'
          ? 'Traitement eau verte'
          : 'Plan d’entretien';
      return `
        <a href="/diagnostic/eau-verte" class="mb-6 flex items-center gap-4 rounded-2xl border border-bleu-ciel bg-bleu-pale/30 p-4 transition hover:bg-bleu-pale/60">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white text-2xl" aria-hidden="true">📋</div>
          <div class="flex-1">
            <p class="text-xs font-medium uppercase tracking-wide text-bleu-eau">Ton planning en cours</p>
            <p class="font-semibold text-noir-eau">${libelle}</p>
            ${dateStr ? `<p class="text-sm text-gris-onde">Sauvegardé le ${dateStr}</p>` : ''}
          </div>
          <span class="text-bleu-eau" aria-hidden="true">→</span>
        </a>`;
    }

    function render() {
      const mesures = getMesuresChlore();
      const planning = getPlanning();
      const planningCard = planning ? cartePlanning(planning) : '';

      if (mesures.length === 0) {
        app!.innerHTML = `
          ${planningCard}
          <div class="rounded-3xl border border-bleu-pale bg-white p-8 text-center shadow-sm">
            <div class="text-5xl" aria-hidden="true">🫧</div>
            <h2 class="mt-4 font-display text-2xl font-semibold text-noir-eau">Aucune mesure pour l'instant</h2>
            <p class="mx-auto mt-2 max-w-sm text-gris-onde">
              Tu n'as pas encore sauvegardé de mesure. Lance un calcul et clique sur « Sauver cette mesure ».
            </p>
            <a href="/calculateur/chlore" class="mt-6 inline-flex items-center justify-center gap-2 rounded-xl bg-bleu-eau px-7 py-3.5 text-base font-medium text-white shadow-sm transition hover:bg-bleu-profond">
              Faire ma première mesure
            </a>
          </div>
          ${teaserHtml}`;
        return;
      }

      app!.innerHTML = `
        ${planningCard}
        <div class="mb-4 flex items-center justify-between">
          <p class="text-sm text-gris-onde">${mesures.length} mesure${mesures.length > 1 ? 's' : ''} enregistrée${mesures.length > 1 ? 's' : ''}</p>
          <a href="/calculateur/chlore" class="text-sm font-semibold text-bleu-eau hover:text-bleu-profond">+ Nouvelle mesure</a>
        </div>
        <ul class="space-y-3">
          ${mesures
            .map((m) => carteMesure(m))
            .join('')}
        </ul>
        ${teaserHtml}`;

      app!
        .querySelectorAll<HTMLButtonElement>('[data-suppr]')
        .forEach((btn) => {
          btn.addEventListener('click', () => {
            const date = btn.getAttribute('data-suppr')!;
            supprimerMesureChlore(date);
            render();
          });
        });
    }

    function carteMesure(m: MesureChlore): string {
      const dose =
        m.grammes > 0
          ? `<span class="font-semibold text-soleil">+${m.grammes.toLocaleString('fr-FR')} g</span> de chlore`
          : `<span class="font-semibold text-vert-ok">Rien à ajouter</span>`;
      return `
        <li class="flex items-start justify-between gap-3 rounded-2xl border border-bleu-pale bg-white p-4 shadow-sm">
          <div>
            <p class="text-xs font-medium uppercase tracking-wide text-gris-onde">${fmtDate(m.date)}</p>
            <p class="mt-1.5 text-noir-eau">
              Chlore <strong>${m.chloreActuel}</strong> → <strong>${m.chloreCible.toFixed(1)}</strong> mg/L
            </p>
            <p class="mt-0.5 text-sm text-gris-onde">${m.volume.toLocaleString('fr-FR')} m³ · ${dose}</p>
          </div>
          <button type="button" data-suppr="${m.date}" aria-label="Supprimer cette mesure"
            class="rounded-lg p-2 text-gris-onde transition hover:bg-rouge-alerte/10 hover:text-rouge-alerte">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          </button>
        </li>`;
    }

    render();
  }

  initSuivi();
  document.addEventListener('astro:page-load', initSuivi);
</script>
