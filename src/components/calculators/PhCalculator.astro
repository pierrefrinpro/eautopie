---
import Input from '../ui/Input.astro';
import Button from '../ui/Button.astro';
---

<div
  class="mx-auto max-w-xl rounded-3xl border border-bleu-pale bg-white p-6 shadow-sm sm:p-8"
  data-ph-calculator
>
  <form id="ph-form" novalidate>
    <Input
      id="ph-volume"
      label="Volume de la piscine"
      type="number"
      placeholder="Ex: 25"
      step="0.1"
      min="0"
      inputmode="decimal"
      suffix="m³"
    />

    <Input
      id="ph-actuel"
      label="pH actuel mesuré"
      type="number"
      placeholder="Ex: 7.8"
      step="0.1"
      min="0"
      max="14"
      inputmode="decimal"
      hint="Mesure-le avec une bandelette ou un testeur."
      class="mt-6"
    />

    <div class="mt-6">
      <div class="flex items-baseline justify-between">
        <label for="ph-cible" class="text-sm font-medium text-noir-eau">
          pH visé
        </label>
        <span
          class="rounded-lg bg-bleu-pale px-2.5 py-1 text-sm font-semibold text-bleu-profond"
        >
          <span id="ph-cible-valeur">7.2</span>
        </span>
      </div>
      <p class="mt-1.5 text-xs text-gris-onde">
        La zone idéale est <strong class="text-noir-eau">7,2 à 7,4</strong>. Laisse
        7,2 si tu hésites.
      </p>
      <input
        id="ph-cible"
        type="range"
        min="7.0"
        max="7.6"
        step="0.1"
        value="7.2"
        class="mt-3 w-full accent-bleu-eau"
      />
      <div class="mt-1 flex justify-between text-xs text-gris-onde">
        <span>7,0</span>
        <span>7,6</span>
      </div>
    </div>

    <div class="mt-7">
      <Button type="submit" variant="primary" size="lg" class="w-full">
        Calculer
      </Button>
    </div>

    <p
      id="ph-erreur"
      style="display: none;"
      class="mt-3 rounded-xl bg-rouge-alerte/10 px-4 py-3 text-sm font-medium text-rouge-alerte"
    >
    </p>
  </form>

  <div id="ph-resultat" hidden class="mt-6">
    <div class="rounded-2xl bg-bleu-profond p-6 text-center text-white">
      <p class="text-sm font-medium uppercase tracking-wide text-bleu-ciel">
        Correction du pH
      </p>
      <p
        id="ph-resultat-titre"
        class="mt-2 text-3xl font-display font-semibold sm:text-4xl"
      >
      </p>
      <p id="ph-resultat-sous" class="mt-2 text-sm text-bleu-ciel"></p>
    </div>

    <div
      class="mt-4 flex items-start gap-3 rounded-2xl border border-bleu-pale bg-bleu-pale/30 p-4 text-sm text-noir-eau"
    >
      <span class="text-lg" aria-hidden="true">💡</span>
      <p>
        Dose de départ indicative : elle dépend de ton alcalinité (TAC) et de ton
        produit. <strong>Verse la moitié</strong>, filtration en marche, re-teste
        après 2-4 h, puis ajuste.
      </p>
    </div>
  </div>
</div>

<script>
  import { calculerCorrectionPh } from '../../lib/calculations';
  import { getVolume, setVolume } from '../../lib/storage';

  function initPh() {
    const root = document.querySelector<HTMLElement>('[data-ph-calculator]');
    if (!root) return;
    const $ = <T extends HTMLElement = HTMLElement>(id: string) =>
      root.querySelector<T>(`#${id}`);

    const form = $<HTMLFormElement>('ph-form');
    const volumeInput = $<HTMLInputElement>('ph-volume');
    const actuelInput = $<HTMLInputElement>('ph-actuel');
    const cibleInput = $<HTMLInputElement>('ph-cible');
    const cibleValeur = $('ph-cible-valeur');
    const erreur = $('ph-erreur');
    const resultat = $('ph-resultat');
    const titre = $('ph-resultat-titre');
    const sous = $('ph-resultat-sous');
    if (!form || !volumeInput || !actuelInput || !cibleInput || !resultat) return;

    const v = getVolume();
    if (v !== null) volumeInput.value = String(v);

    const majCible = () => {
      if (cibleValeur)
        cibleValeur.textContent = Number(cibleInput.value).toFixed(1);
    };
    cibleInput.addEventListener('input', majCible);
    majCible();

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (erreur) erreur.style.display = 'none';

      const volume = parseFloat(volumeInput.value);
      const phActuel = parseFloat(actuelInput.value);
      const phCible = parseFloat(cibleInput.value);

      if (!Number.isFinite(volume) || volume <= 0) {
        if (erreur) {
          erreur.textContent = 'Indique le volume de ta piscine (en m³).';
          erreur.style.display = 'block';
        }
        return;
      }
      if (!Number.isFinite(phActuel) || phActuel <= 0 || phActuel > 14) {
        if (erreur) {
          erreur.textContent = 'Indique ton pH actuel mesuré (entre 0 et 14).';
          erreur.style.display = 'block';
        }
        return;
      }
      setVolume(volume);

      const { sens, grammes, produit } = calculerCorrectionPh(
        volume,
        phActuel,
        phCible
      );

      if (titre && sous) {
        if (sens === 'ok') {
          titre.textContent = 'Ton pH est déjà bon 👍';
          sous.textContent = `À ${phActuel}, tu es dans la zone visée. Rien à ajouter.`;
        } else {
          const verbe = sens === 'baisser' ? 'baisser' : 'monter';
          titre.innerHTML = `Ajoute <span class="text-soleil">${grammes.toLocaleString('fr-FR')} g</span> de ${produit}`;
          sous.textContent = `Pour ${verbe} ton pH de ${phActuel} vers ${phCible.toFixed(1)} dans ${volume.toLocaleString('fr-FR')} m³.`;
        }
      }

      resultat.hidden = false;
      resultat.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  }

  initPh();
  document.addEventListener('astro:page-load', initPh);
</script>
