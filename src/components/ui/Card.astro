---
interface Props {
  class?: string;
  as?: string;
}

const { class: className = '', as = 'div' } = Astro.props;
const Tag = as as any;
---

<Tag
  class={`rounded-2xl border border-bleu-pale bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg ${className}`}
>
  <slot />
</Tag>
