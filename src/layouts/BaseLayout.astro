---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { GTM_ID, GA_ID } from '../consts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'EauTopie — l’eau parfaite de ta piscine, sans casse-tête',
  description = 'EauTopie t’aide à entretenir ta piscine : calculateurs de doses précis, diagnostic des problèmes d’eau, et suivi de tes paramètres. Pas besoin d’être pisciniste.',
  image = '/og-image.png',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {/* Google Tag Manager */}
    {
      GTM_ID && (
        <script
          is:inline
          set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${GTM_ID}');`}
        />
      )
    }
    {/* Google Analytics 4 (direct) */}
    {
      GA_ID && (
        <Fragment>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
          />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA_ID}');`}
          />
        </Fragment>
      )
    }

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta name="theme-color" content="#0EA5E9" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="EauTopie" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="flex min-h-screen flex-col">
    {/* Google Tag Manager (noscript) */}
    {
      GTM_ID && (
        <noscript
          set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`}
        />
      )
    }
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      // Si l'utilisateur est déjà sur la waitlist Premium, on transforme tous
      // les boutons « Passer à Premium » en état « inscrit » (désactivé, visuel).
      const PREMIUM_KEY = 'eautopie_premium_signup';

      function majBoutonsPremium() {
        let inscrit = false;
        try {
          inscrit = !!window.localStorage.getItem(PREMIUM_KEY);
        } catch {
          inscrit = false;
        }
        if (!inscrit) return;

        document
          .querySelectorAll<HTMLAnchorElement>('[data-premium-btn]')
          .forEach((el) => {
            const label =
              el.querySelector<HTMLElement>('[data-premium-label]') ?? el;
            label.textContent = 'Tu es sur la waitlist ✓';
            el.removeAttribute('href');
            el.setAttribute('aria-disabled', 'true');
            el.classList.add(
              'cursor-default',
              'opacity-70',
              'pointer-events-none'
            );
          });
      }

      majBoutonsPremium();
      document.addEventListener('astro:page-load', majBoutonsPremium);
    </script>
  </body>
</html>
